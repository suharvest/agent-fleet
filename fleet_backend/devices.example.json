{
  "_meta": {
    "description": "Example Fleet device inventory. Copy to devices.json and fill in your own hosts. Do not commit real passwords.",
    "schema": {
      "devices": {
        "<name>": {
          "host": "IP address or hostname",
          "port": "optional SSH port, defaults to 22",
          "user": "SSH username",
          "password": "optional SSH password; leave empty to use SSH keys",
          "owner": "personal or company",
          "tags": ["linux", "arm64", "edge"],
          "description": "human-readable description",
          "gateway": "optional Windows gateway device name for WSL2 devices",
          "wsl_distro": "optional WSL distro name"
        }
      }
    }
  },
  "devices": {
